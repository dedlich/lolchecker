# Copy to `.env` for local development. NEVER commit a real `.env`.
# Production secrets belong in keyring (Windows Credential Manager).

# --- Claude / Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Logging ---
LOG_LEVEL=INFO

# --- Dev toggles ---
# Forces the FixtureLcuSource even without --dry-run.
CHAMP_ASSISTANT_DRY_RUN=0

# Override Data Dragon patch version (otherwise auto-detected).
# DDRAGON_PATCH=14.8.1
