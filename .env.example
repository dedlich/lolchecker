# Copy this to `.env` next to champ-assistant.exe to enable optional features.
# `.env` is auto-loaded at startup. Never commit your real `.env`.

# --- Groq (free LLM API for live counter fetching) ---
# Sign up at https://console.groq.com (free, ~14k requests/day).
# Without this key, counters fall back to the bundled JSON seed data only.
GROQ_API_KEY=

# --- Anthropic (Claude API for AI Explain feature, Phase 7) ---
# Optional. Used only when the in-app AI Explain button is clicked.
# Costs ~$0.001 per matchup explanation.
ANTHROPIC_API_KEY=

# --- App-internal ---
LOG_LEVEL=INFO
# Force the FixtureLcuSource even without --dry-run (dev only).
CHAMP_ASSISTANT_DRY_RUN=0
